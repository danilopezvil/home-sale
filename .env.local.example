# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and never committed.

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin access ──────────────────────────────────────────
# Comma-separated list of email addresses allowed to access /admin
ADMIN_EMAILS=admin@example.com

# ── Email (optional) ─────────────────────────────────────
# Remove or leave blank to disable email notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Site URL (optional) ───────────────────────────────────
# Used in admin notification email CTA link
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── REST API (optional) ───────────────────────────────────
# Min 32 characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY=

# ── LLM for image analysis (optional) ───────────────────
# Select provider: gemini (default, free tier) | anthropic
LLM_PROVIDER=gemini

# Gemini — get key at https://aistudio.google.com/apikey (free tier available)
GEMINI_API_KEY=

# Anthropic — only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
